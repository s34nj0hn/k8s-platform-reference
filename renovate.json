    "managerFilePatterns": ["/GitOps/.+\\.ya?ml$/"]
  },
  "packageRules": [
    {
      "description": "Group Kubernetes platform image updates",
      "matchDatasources": ["docker"],
      "groupName": "container images"
    }
  ]
}
